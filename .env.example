# Example env file — copy to `.env.local` (local dev) or configure in Vercel dashboard.
# All variables below are REQUIRED unless noted.

# ---- Supabase ---------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin auth -------------------------------------------------------
# IMPORTANT: bcrypt hashes contain "$" characters. Next.js env parser
# interprets $ as variable expansion, so you MUST escape each $ with a
# backslash when placing the hash in a local .env file.
# Example (hash of "attikid"):
#   ADMIN_PASSWORD_HASH=\$2b\$10\$lmAcKpRT4/dZBrLIi806Dei1PyzlDkoDf07Ap97SAhVaeGMlDQWY2
# On Vercel you can paste the raw hash as-is in the dashboard (no escaping needed).
ADMIN_PASSWORD_HASH=\$2b\$10\$replace-with-your-bcrypt-hash

# ---- Optional ---------------------------------------------------------
# CORS origin for the API (default: *)
# CORS_ORIGINS=*
